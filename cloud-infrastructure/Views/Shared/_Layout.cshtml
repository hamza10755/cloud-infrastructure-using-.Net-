<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CloudPortal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex" style="min-height: 100vh;">
        <nav class="sidebar custom-bg-dark text-white d-flex flex-column p-3">
            <h4 class="fw-bold ps-2 mb-4">CloudPortal</h4>
            <ul class="nav nav-pills flex-column mb-auto">
                @if (User.IsInRole("Developer"))
                {
                    <li class="nav-item"><a asp-controller="Developer" asp-action="RequestVM" class="nav-link text-white"><i class="bi bi-grid-1x2 me-2"></i> Request New VM</a></li>
                }

                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item"><a asp-controller="Admin" asp-action="Index" class="nav-link text-white"><i class="bi bi-shield-lock me-2"></i> Admin Dashboard</a></li>
                    <li class="nav-item"><a asp-controller="Admin" asp-action="ManageUsers" class="nav-link text-white"><i class="bi bi-people me-2"></i> Manage Users</a></li>
                    <li class="nav-item"><a asp-controller="Admin" asp-action="ServerHistory" class="nav-link text-white"><i class="bi bi-clock-history me-2"></i> Server History</a></li>
                }
            </ul>
        </nav>

        <div class="content flex-grow-1 d-flex flex-column custom-bg-light">
            <header class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom px-4 py-2">
                <div class="ms-auto d-flex align-items-center">
                    <partial name="_LoginPartial" />
                </div>
            </header>

            <main class="p-4 flex-grow-1">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>