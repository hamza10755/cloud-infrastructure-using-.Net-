@using Microsoft.AspNetCore.Identity
@using cloud_infrastructure.Models
@inject SignInManager<Developer> SignInManager
@inject UserManager<Developer> UserManager

<ul class="navbar-nav ms-auto mb-2 mb-lg-0">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item d-flex align-items-center gap-3">
        <span class="text-white-50 small">@User.Identity?.Name</span>
        <form class="mb-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>