@using Microsoft.AspNetCore.Identity
@using cloud_infrastructure.Models
@inject SignInManager<Developer> SignInManager
@inject UserManager<Developer> UserManager

<ul class="navbar-nav ms-auto mb-2 mb-lg-0">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <form class="form-inline d-flex align-items-center gap-2" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="button" class="btn btn-outline-light" data-bs-toggle="modal" data-bs-target="#provisionServerModal">+ Request Server</button>
            <button type="submit" class="nav-link btn btn-link text-white">Logout @User.Identity?.Name</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>