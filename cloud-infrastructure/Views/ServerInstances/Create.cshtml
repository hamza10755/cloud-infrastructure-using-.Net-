@model cloud_infrastructure.Models.ServerInstance

<h2>Create Server</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label>Hostname</label>
        <input asp-for="Hostname" class="form-control" />
        <span asp-validation-for="Hostname" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>RAM</label>
        <input asp-for="RamGb" class="form-control" type="number" />
        <span asp-validation-for="RamGb" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Instance Size</label>

        <select asp-for="InstanceSize" class="form-control">
            <option value="1">Small</option>
            <option value="2">Medium</option>
            <option value="3">Large</option>
            <option value="4">XL</option>
            <option value="5">XXL</option>
        </select>

        <span asp-validation-for="InstanceSize" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
