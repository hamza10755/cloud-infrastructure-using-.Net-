@model ServerInstance

@{
    ViewData["Title"] = $"Server #{Model.ServerInstanceId}";
}

<style>
    .detail-card {
        background: #1c2128;
        border: 1px solid #30363d;
        border-radius: 12px;
        color: #e6edf3;
    }

    .detail-label {
        color: #8b949e;
        font-size: 0.82rem;
    }

    .detail-value {
        font-size: 1.05rem;
    }

    .badge-approved { background: rgba(63,185,80,.15); color: #3fb950; }
    .badge-pending { background: rgba(210,153,34,.15); color: #d29922; }
    .badge-rejected { background: rgba(248,81,73,.12); color: #f85149; }
</style>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="mb-1">@Model.Hostname</h2>
        <div class="text-muted">Server request details.</div>
    </div>
    <a asp-action="ServerHistory" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to History
    </a>
</div>

<div class="row g-4">
    <div class="col-12 col-lg-8">
        <div class="detail-card p-4">
            <div class="row g-4">
                <div class="col-6 col-md-4">
                    <div class="detail-label">Server ID</div>
                    <div class="detail-value"><code>#@Model.ServerInstanceId</code></div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="detail-label">Hostname</div>
                    <div class="detail-value fw-semibold">@Model.Hostname</div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="detail-label">Status</div>
                    <div class="detail-value">
                        <partial name="_StatusBadge" model="Model.Status" />
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="detail-label">RAM</div>
                    <div class="detail-value">@Model.RamGb GB</div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="detail-label">Operating System</div>
                    <div class="detail-value">@Model.OperatingSystem</div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="detail-label">Instance Size</div>
                    <div class="detail-value">@Model.InstanceSize</div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="detail-label">Developer</div>
                    <div class="detail-value">@(Model.Developer?.UserName ?? Model.DeveloperId ?? "-")</div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="detail-label">Email</div>
                    <div class="detail-value">@(Model.Developer?.Email ?? "-")</div>
                </div>
                <div class="col-12">
                    <div class="detail-label">Purpose</div>
                    <div class="detail-value">@(Model.Purpose ?? "-")</div>
                </div>
                <div class="col-12 mt-4">
                    <div class="detail-label mb-2 fw-semibold text-info">Requested Software Packages</div>
                    <div class="row g-2">
                        @if (Model.ServerSoftwares != null && Model.ServerSoftwares.Any())
                        {
                            @foreach (var ss in Model.ServerSoftwares)
                            {
                                @if (ss.SoftwarePackage != null)
                                {
                                    <div class="col-6 col-md-4">
                                        <div class="p-2 rounded border border-secondary" style="background: #0d1117;">
                                            <i class="bi bi-box-seam text-info me-2"></i>
                                            <span class="fw-semibold">@ss.SoftwarePackage.PackageName</span>
                                            <span class="text-muted small ms-1">v@ss.SoftwarePackage.Version</span>
                                        </div>
                                    </div>
                                }
                            }
                        }
                        else
                        {
                            <div class="col-12 text-muted small ps-3">No software packages requested for this server instance.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
