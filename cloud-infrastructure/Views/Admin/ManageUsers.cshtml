@model ManageUsersViewModel

@{
    ViewData["Title"] = "Manage Users";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="mb-1">Manage Users</h2>
        <div class="text-muted">View all registered users and manage their roles.</div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
    </a>
</div>

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card bg-dark border-secondary">
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Roles</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Users.Any())
                {
                    foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>@user.UserName</td>
                            <td>@user.Email</td>
                            <td>
                                @foreach (var role in user.Roles)
                                {
                                    <span class="badge @(role == "Admin" ? "bg-warning text-dark" : "bg-secondary") me-1">@role</span>
                                }
                            </td>
                            <td class="text-end">
                                <form asp-action="UpdateRoles" method="post" class="d-inline-flex align-items-center gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.UserId" />
                                    @{
                                        var isDevOnly = user.Roles.Count == 1 && user.Roles.Contains("Developer");
                                        var isAdminOnly = user.Roles.Count == 1 && user.Roles.Contains("Admin");
                                        var isBoth = user.Roles.Count > 1;
                                    }
                                    <select name="role" class="form-select form-select-sm bg-dark text-white border-secondary" style="width: auto;">
                                        @if (isDevOnly) { @:<option value="Developer" selected>Developer</option>
                                        } else { @:<option value="Developer">Developer</option>
                                        }
                                        @if (isAdminOnly) { @:<option value="Admin" selected>Admin</option>
                                        } else { @:<option value="Admin">Admin</option>
                                        }
                                        @if (isBoth) { @:<option value="Both" selected>Both</option>
                                        } else { @:<option value="Both">Both</option>
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-outline-light">Save</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">No users registered yet.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
