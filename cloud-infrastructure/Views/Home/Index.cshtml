@model IEnumerable<cloud_infrastructure.Models.ServerInstance>

@{
    ViewData["Title"] = "Home";
}

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="container py-3">
        <h2 class="mb-4">Approval Queue</h2>

        @if (Model == null || !Model.Any())
        {
            <div class="alert alert-secondary text-white">No pending server requests.</div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 g-3">
                @foreach (var item in Model)
                {
                    <div class="col">
                        <div class="card h-100 bg-dark text-white border-secondary">
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title text-info">@item.Hostname</h5>
                                <p class="card-text mb-1"><strong>RAM:</strong> @item.RamGb GB</p>
                                <p class="card-text mb-1"><strong>Size:</strong> @item.InstanceSize</p>
                                <p class="card-text mb-2"><strong>Requested by:</strong> @item.DeveloperId</p>

                                <div class="mt-auto d-flex gap-2">
                                    <form asp-controller="Infrastructure" asp-action="ApproveServer" method="post">
                                        <input type="hidden" name="id" value="@item.ServerInstanceId" />
                                        <button type="submit" class="btn btn-success btn-sm">Approve</button>
                                        @Html.AntiForgeryToken()
                                    </form>

                                    <form asp-controller="Infrastructure" asp-action="RejectServer" method="post">
                                        <input type="hidden" name="id" value="@item.ServerInstanceId" />
                                        <button type="submit" class="btn btn-danger btn-sm">Reject</button>
                                        @Html.AntiForgeryToken()
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}
else
{
    <div class="container py-5">
        <div class="p-5 mb-4 bg-dark text-white rounded-3 border border-secondary shadow-lg">
            <div class="container-fluid py-5 text-center">
                <h1 class="display-5 fw-bold text-info mb-3">@ViewBag.MainHeader</h1>
                <p class="col-md-8 fs-5 mx-auto text-muted">@ViewData["PortalMessage"]</p>
                
                @if (ViewBag.ShowInfoAlert == true)
                {
                    <div class="alert alert-info bg-dark-subtle border-info text-info col-md-6 mx-auto mb-4" role="alert">
                        <i class="bi bi-info-circle me-2"></i> Only authenticated users can access the provisioning portals.
                    </div>
                }

                <div class="d-grid gap-2 d-sm-flex justify-content-sm-center mt-4">
                    <a class="btn btn-primary btn-lg px-4 me-sm-3 fw-bold" href="/Identity/Account/Login">Sign In</a>
                    <a class="btn btn-outline-secondary btn-lg px-4" href="/Identity/Account/Register">Register</a>
                </div>
            </div>
        </div>
    </div>
}
