@model IEnumerable<cloud_infrastructure.Models.ServerInstance>

@{
    ViewData["Title"] = "Approval Queue";
}

<div class="container py-3">
    <h2 class="mb-4">Approval Queue</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-secondary">No pending server requests.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-3">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@item.Hostname</h5>
                            <p class="card-text mb-1"><strong>RAM:</strong> @item.RamGb GB</p>
                            <p class="card-text mb-1"><strong>Size:</strong> @item.InstanceSize</p>
                            <p class="card-text mb-2"><strong>Requested by:</strong> @item.DeveloperId</p>

                            <div class="mt-auto d-flex gap-2">
                                <form asp-controller="Infrastructure" asp-action="ApproveServer" method="post">
                                    <input type="hidden" name="id" value="@item.ServerInstanceId" />
                                    <button type="submit" class="btn btn-success btn-sm">Approve</button>
                                    @Html.AntiForgeryToken()
                                </form>

                                <form asp-controller="Infrastructure" asp-action="RejectServer" method="post">
                                    <input type="hidden" name="id" value="@item.ServerInstanceId" />
                                    <button type="submit" class="btn btn-danger btn-sm">Reject</button>
                                    @Html.AntiForgeryToken()
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
