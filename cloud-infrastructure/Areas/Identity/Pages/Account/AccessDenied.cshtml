@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
}

<div class="container py-5 text-center" style="max-width: 500px;">
    <i class="bi bi-shield-exclamation" style="font-size: 4rem; color: #d29922;"></i>
    <h1 class="mt-3">Access Denied</h1>
    <p class="text-muted mb-4">
        You do not have permission to access this page.
        @if (!string.IsNullOrWhiteSpace(Model?.Message))
        {
            <br />@Model.Message
        }
    </p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Go to Home</a>
</div>
